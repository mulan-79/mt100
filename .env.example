# Firebase Web 앱 설정 (콘솔 → 프로젝트 설정 → 일반 → 내 앱)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# true 로 두면 `mountains` 컬렉션이 비어 있을 때 src/data/mountainsSeed.js 데이터를 한 번에 업로드합니다.
# Firestore 규칙에서 쓰기가 허용되어야 합니다(개발용).
# VITE_FIREBASE_SEED_IF_EMPTY=true
